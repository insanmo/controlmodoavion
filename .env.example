# Variables de entorno de ejemplo para Control Modo Avión / AirControl.
# Copia este archivo a .env.local para desarrollo local y a .env.production para el build de GitHub Pages.
#
# No hardcodear estas variables dentro del código. Se leen con import.meta.env.

# URL del proyecto Supabase (remoto).
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Anon key pública de Supabase (segura de exponer en el frontend).
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY_PUBLICA

# Entorno: local | production
VITE_APP_ENV=local

# Ruta base. Local suele ser "/" ; Producción debe ser "/NOMBRE_REPO/" (p.ej. /controlmodoavion/).
VITE_BASE_PATH=/
